# Supabase — 共有リンク（配置・音源・参考動画）用
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Dashboard の SQL Editor が使えないとき: npm run supabase:setup
# Supabase → Project Settings → Database → Connection string (URI)
SUPABASE_DB_URL=postgresql://postgres.YOUR_REF:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres

# 本番 URL（Vercel 等）。設定すると共有リンクにこの URL が使われます
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

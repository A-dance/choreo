# Copy to .env.local and fill in values (never commit .env.local).

# --- Supabase (Auth / DB / Storage) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: apply schema via `npm run supabase:setup`
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# --- App URLs ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Google Gemini (ASK AI: POST /api/help) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Stripe (Pro subscription) ---
STRIPE_SECRET_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# --- Demo scripts (optional overrides for npm run demo:*) ---
# NEXT_PUBLIC_DEMO_EMAIL=demo@bamiri.share
# NEXT_PUBLIC_DEMO_PASSWORD=Demo1234
# DEMO_PLAN=pro

# E2E: デモログイン試験（ローカルのみ。終了後に demo ワークスペースを復元）
# E2E_DEMO_LOGIN=1

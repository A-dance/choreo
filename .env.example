# Supabase — 共有リンク + ログイン / クラウド同期
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Dashboard の SQL Editor が使えないとき: npm run supabase:setup
# Supabase → Project Settings → Database → Connection string (URI)
SUPABASE_DB_URL=postgresql://postgres.YOUR_REF:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres

# 本番 URL（Vercel 等）。設定すると共有リンク・パスワード再設定メールにこの URL が使われます
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Googleログイン: Supabase → Authentication → Providers → Google を有効化
# Gemini ヘルプ: https://aistudio.google.com/apikey でキーを取得
GEMINI_API_KEY=your-gemini-api-key
# 任意: gemini-2.5-flash（既定） / gemini-2.0-flash など
# GEMINI_MODEL=gemini-2.5-flash

# Stripe（テスト / サンドボックス）— Dashboard → Developers → API keys
# 公開可能キー（pk_test_...）とシークレットキー（sk_test_...）を使用
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_SECRET_KEY=sk_test_your-secret-key
# Pro 月額プランの Price ID（Products → Pro → Pricing → price_...）
STRIPE_PRO_PRICE_ID=price_your-pro-price-id
# Webhook 署名シークレット
# ローカル: stripe listen --forward-to localhost:3000/api/stripe/webhook
# 本番: Dashboard → Webhooks → https://your-app.vercel.app/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# --- 本番（Live mode）に切り替えるとき ---
# 1. Stripe Dashboard 右上を「Test mode」→「Live mode」に切り替え
# 2. Live 用の API keys（pk_live_ / sk_live_）を Vercel 本番環境変数に設定
# 3. Live モードで Pro 商品・Price を新規作成し STRIPE_PRO_PRICE_ID を差し替え
# 4. Live Webhook を本番 URL に登録し STRIPE_WEBHOOK_SECRET を差し替え
# 5. Customer Portal を Dashboard → Settings → Billing → Customer portal で有効化
# ※ テストと本番の顧客・サブスクは完全に別。テスト決済は本番に影響しません。

# Redirect URL（Google Cloud Console）: https://YOUR_PROJECT.supabase.co/auth/v1/callback
# Supabase → Authentication → URL Configuration:
#   Site URL: 本番のトップ URL（例 https://your-app.vercel.app）
#   Redirect URLs に追加:
#     http://localhost:3000/auth/callback
#     http://localhost:3000/auth/reset-password
#     https://your-app.vercel.app/auth/callback
#     https://your-app.vercel.app/auth/reset-password

# デモアカウント（評価・デモ用。UI ボタンはなし）
# 作成・データ投入: npm run demo:setup
# ログイン: demo@bamiri.share / Demo1234

{
  "name": "choreo",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src/lib src/app/api tests e2e scripts vitest.config.ts playwright.config.ts eslint.config.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "supabase:setup": "node scripts/setup-supabase.mjs",
    "supabase:setup-cli": "supabase db execute -f supabase/schema.sql",
    "demo:user": "node scripts/create-demo-user.mjs",
    "demo:workspace": "node scripts/seed-demo-workspace.mjs",
    "demo:setup": "node scripts/create-demo-user.mjs && node scripts/seed-demo-workspace.mjs",
    "docs:capture": "node scripts/capture-readme-assets.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.2.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.5",
    "ffmpeg-static": "^5.2.0",
    "pg": "^8.21.0",
    "prettier": "^3.6.2",
    "@playwright/test": "^1.60.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
